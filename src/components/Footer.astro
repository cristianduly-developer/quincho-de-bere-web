---
import { NEGOCIO, waLink, AGENDA_URL } from '../data/negocio';
---

<!-- CTA noche -->
<section class="cta-night">
  <div class="bgimg"><img src="/img/galeria/nocturna-fogon.jpg" alt="Fogón de noche" /></div>
  <div class="scrim"></div>
  <div class="cta-night-inner">
    <p class="eyebrow">Reservá tu fecha</p>
    <h2>Tu próxima celebración<br/>empieza acá.</h2>
    <p>Contanos qué estás festejando y te ayudamos a elegir el turno ideal.</p>
    <div class="ctas">
      <a href={AGENDA_URL} class="btn btn-primary" target="_blank" rel="noopener noreferrer">
        Ver fechas disponibles
      </a>
      <a href={waLink('Hola! Quiero reservar una fecha en El Quincho de Bere.')} class="btn btn-ghost" target="_blank" rel="noopener noreferrer">
        Consultar por WhatsApp
      </a>
      <a href="#sectores" class="btn btn-ghost">Ver el lugar de nuevo</a>
    </div>
  </div>
</section>

<footer>
  <div class="wrap">
    <div class="footer-grid">
      <div class="footer-brand">
        <img src="/img/logo.jpeg" alt={NEGOCIO.nombre} />
        {NEGOCIO.nombre}
      </div>
      <div class="footer-links">
        <a href="#sectores">Sectores</a>
        <a href="#turnos">Turnos</a>
        <a href="#extras">Extras</a>
        <a href="#faq">Preguntas</a>
        <a href={NEGOCIO.instagram} target="_blank" rel="noopener noreferrer">Instagram</a>
        <a href={NEGOCIO.tiktok} target="_blank" rel="noopener noreferrer">TikTok</a>
      </div>
    </div>
    <div class="footer-bottom">
      <span>{NEGOCIO.direccion}</span>
      <span>{NEGOCIO.whatsappDisplay}</span>
    </div>
  </div>
</footer>

<style>
  /* CTA noche */
  .cta-night { position: relative; color: var(--beige-50); overflow: hidden; }
  .cta-night .bgimg { position: absolute; inset: 0; }
  .cta-night .bgimg img { width: 100%; height: 100%; object-fit: cover; }
  .cta-night .scrim {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 50% 30%, rgba(212,175,106,.22), transparent 60%),
      linear-gradient(to top, rgba(15,31,25,.97), rgba(15,31,25,.75) 55%, rgba(15,31,25,.55));
  }
  .cta-night-inner { position: relative; z-index: 1; text-align: center; padding: 110px 24px; }
  .eyebrow { font-size: .72rem; letter-spacing: .22em; text-transform: uppercase; color: var(--oro-400); font-weight: 700; margin: 0 0 16px; }
  .cta-night h2 {
    font-family: var(--font-display); font-weight: 600;
    font-size: clamp(2rem, 4.6vw, 3.2rem);
    margin: 0 0 18px; line-height: 1.1; color: var(--beige-50);
  }
  .cta-night p { color: rgba(255,252,246,.75); max-width: 46ch; margin: 0 auto 34px; font-size: 1.02rem; }
  .ctas { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }

  .btn {
    display: inline-flex; align-items: center; gap: .5rem;
    padding: .95rem 1.9rem; border-radius: 999px;
    font-weight: 700; font-size: .92rem;
    transition: transform .18s ease, box-shadow .18s ease, background .18s ease;
    white-space: nowrap; text-decoration: none;
  }
  .btn-primary { background: var(--oro-400); color: var(--verde-950); }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 24px -8px rgba(212,175,106,.55); }
  .btn-ghost { background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.4); color: #fff; backdrop-filter: blur(6px); }
  .btn-ghost:hover { background: rgba(255,255,255,.18); transform: translateY(-2px); }

  /* Footer */
  footer { background: var(--verde-950); color: rgba(255,252,246,.6); padding: 48px 0 28px; }
  .wrap { max-width: 1180px; margin: 0 auto; padding: 0 24px; }
  .footer-grid { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 24px; padding-bottom: 28px; border-bottom: 1px solid rgba(255,252,246,.12); }
  .footer-brand { display: flex; align-items: center; gap: 10px; color: var(--beige-50); font-family: var(--font-display); font-weight: 600; font-size: 1rem; }
  .footer-brand img { width: 32px; height: 32px; border-radius: 50%; background: #fff; padding: 2px; object-fit: cover; }
  .footer-links { display: flex; gap: 34px; font-size: .85rem; flex-wrap: wrap; }
  .footer-links a { color: rgba(255,252,246,.6); text-decoration: none; transition: color .2s; }
  .footer-links a:hover { color: var(--oro-400); }
  .footer-bottom { padding-top: 20px; font-size: .75rem; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 10px; }
</style>
