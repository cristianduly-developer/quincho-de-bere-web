---
import { waLink, AGENDA_URL } from '../data/negocio';
---
<section class="hero">
  <div class="hero-bg">
    <img src="/img/galeria/exterior-frente.jpg" alt="El Quincho de Bere" />
  </div>
  <div class="hero-scrim"></div>
  <div class="hero-content">
    <p class="eyebrow">San Martín 9620 · Mar del Plata</p>
    <h1 class="hero-title">El lugar donde nacen los mejores <em>recuerdos</em>.</h1>
    <p class="hero-sub">Quincho cerrado, pileta, fogón y un parque entero para vos, tu familia y hasta 40 invitados.</p>
    <div class="hero-ctas">
      <a href="#sectores" class="btn btn-ghost">Ver el lugar</a>
      <a href={AGENDA_URL} class="btn btn-primary" target="_blank" rel="noopener noreferrer">
        Ver fechas disponibles
      </a>
    </div>
  </div>
  <div class="hero-meta">Capacidad 40 personas<br/>Turno día · noche · completo</div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 96svh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: var(--verde-950);
  }
  .hero-bg { position: absolute; inset: 0; }
  .hero-bg img { width: 100%; height: 100%; object-fit: cover; }
  .hero-scrim {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(15,31,25,.95) 0%, rgba(15,31,25,.55) 42%, rgba(15,31,25,.15) 68%, rgba(15,31,25,.35) 100%);
  }
  .hero-content {
    position: relative; z-index: 2;
    width: 100%; padding: 0 24px 76px;
    max-width: 1180px; margin: 0 auto;
  }
  .eyebrow {
    font-size: .72rem; letter-spacing: .22em; text-transform: uppercase;
    color: var(--oro-400); font-weight: 700; margin: 0 0 12px;
  }
  .hero-title {
    font-family: var(--font-display);
    color: var(--beige-50);
    font-weight: 600;
    font-size: clamp(2.6rem, 6.4vw, 5rem);
    line-height: 1.02;
    letter-spacing: -0.015em;
    max-width: 16ch;
    margin: 0 0 20px;
  }
  .hero-title em { font-style: italic; color: var(--beige-50); font-weight: 500; }
  .hero-sub {
    color: rgba(248,242,230,.82);
    font-size: 1.05rem;
    max-width: 44ch;
    margin: 0 0 34px;
    line-height: 1.55;
  }
  .hero-ctas { display: flex; gap: 14px; flex-wrap: wrap; }
  .hero-meta {
    position: absolute; right: 24px; bottom: 34px; z-index: 2;
    text-align: right; color: rgba(248,242,230,.55);
    font-size: .78rem; display: none;
  }
  @media(min-width: 900px) { .hero-meta { display: block; } }

  .btn {
    display: inline-flex; align-items: center; gap: .5rem;
    padding: .95rem 1.9rem; border-radius: 999px;
    font-weight: 700; font-size: .92rem;
    transition: transform .18s ease, box-shadow .18s ease, background .18s ease;
    white-space: nowrap; text-decoration: none;
  }
  .btn-primary { background: var(--oro-400); color: var(--verde-950); }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 24px -8px rgba(212,175,106,.55); }
  .btn-ghost { background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.4); color: #fff; backdrop-filter: blur(6px); }
  .btn-ghost:hover { background: rgba(255,255,255,.18); transform: translateY(-2px); }
</style>
