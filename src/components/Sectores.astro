---
import { SECTORES } from '../data/negocio';
---
<section id="sectores" class="reveal">
  <div class="wrap">
    <p class="eyebrow">El lugar</p>
    <h2 class="headline">Recorré el Quincho<br/>por <em>sectores</em>.</h2>
    <p class="lead">Tocá cada foto para conocer cada rincón.</p>

    <div class="bento">
      {SECTORES.slice(0, 5).map((sector, i) => (
        <button
          type="button"
          class:list={["tile", i === 0 ? "big" : ""]}
          data-sector-id={sector.id}
        >
          <img src={sector.imgs[0]} alt={sector.nombre} />
          <div class="tile-scrim"></div>
          <div class="tile-label">
            <div class="name"><span>{sector.icon}</span> {sector.nombre}</div>
            {i === 0 && <div class="sub">{sector.frase}</div>}
          </div>
        </button>
      ))}
    </div>
  </div>
</section>

<!-- Modal -->
<div id="sector-modal" class="sector-modal hidden">
  <button id="sector-modal-cerrar" class="modal-cerrar" aria-label="Cerrar">×</button>
  <div class="modal-inner">
    <div class="modal-header">
      <p id="sector-modal-titulo" class="modal-titulo"></p>
      <p id="sector-modal-frase" class="modal-frase"></p>
    </div>
    <div class="modal-img-wrap">
      <img id="sector-modal-img" src="" alt="" />
      <button id="sector-modal-prev" aria-label="Anterior" class="modal-nav modal-prev">‹</button>
      <button id="sector-modal-next" aria-label="Siguiente" class="modal-nav modal-next">›</button>
    </div>
    <p id="sector-modal-contador" class="modal-contador"></p>
  </div>
</div>

<style>
  section { padding: 96px 0; }
  .wrap { max-width: 1180px; margin: 0 auto; padding: 0 24px; }
  .eyebrow {
    font-size: .72rem; letter-spacing: .22em; text-transform: uppercase;
    color: var(--madera-600); font-weight: 700; margin: 0 0 12px;
  }
  .headline {
    font-family: var(--font-display); font-weight: 600;
    font-size: clamp(1.9rem, 3.6vw, 2.8rem);
    line-height: 1.1; margin: 0 0 14px; letter-spacing: -0.01em;
  }
  .headline em { font-style: italic; color: var(--madera-600); font-weight: 500; }
  .lead { color: rgba(15,31,25,.62); font-size: 1.02rem; line-height: 1.6; max-width: 46ch; margin: 0 0 48px; }

  .bento {
    display: grid; grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 150px; gap: 14px;
  }
  .tile { grid-column: span 1; grid-row: span 1; }
  .tile.big { grid-column: span 2; grid-row: span 2; }
  @media(max-width: 760px) {
    .bento { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 130px; }
    .tile.big { grid-column: span 2; grid-row: span 2; }
  }

  .tile {
    position: relative; border-radius: 16px; overflow: hidden;
    display: block; cursor: pointer; border: none; padding: 0;
  }
  .tile img { width: 100%; height: 100%; object-fit: cover; transition: transform .6s cubic-bezier(.2,.7,.2,1); }
  .tile:hover img { transform: scale(1.08); }
  .tile-scrim { position: absolute; inset: 0; background: linear-gradient(to top, rgba(15,31,25,.85) 0%, rgba(15,31,25,.05) 55%); }
  .tile-label { position: absolute; left: 12px; bottom: 10px; right: 12px; color: var(--beige-50); text-align: left; }
  .tile-label .name { font-family: var(--font-display); font-weight: 600; font-size: .95rem; display: flex; gap: 6px; align-items: center; }
  .tile.big .tile-label .name { font-size: 1.25rem; }
  .tile-label .sub { font-size: .72rem; color: rgba(248,242,230,.7); margin-top: 2px; }

  /* modal */
  .sector-modal {
    position: fixed; inset: 0; z-index: 60;
    background: rgba(15,31,25,.92);
    display: flex; align-items: center; justify-content: center; padding: 1rem;
  }
  .sector-modal.hidden { display: none; }
  .modal-cerrar {
    position: absolute; top: 24px; right: 24px;
    background: none; border: none; color: var(--beige-50);
    font-size: 2rem; cursor: pointer; line-height: 1;
  }
  .modal-inner { width: 100%; max-width: 680px; }
  .modal-header { text-align: center; margin-bottom: 16px; }
  .modal-titulo { font-family: var(--font-display); font-size: 1.5rem; font-weight: 600; color: var(--beige-50); margin: 0 0 6px; }
  .modal-frase { color: rgba(248,242,230,.7); font-size: .88rem; margin: 0; }
  .modal-img-wrap { position: relative; aspect-ratio: 16/9; border-radius: 16px; overflow: hidden; background: var(--verde-900); }
  .modal-img-wrap img { width: 100%; height: 100%; object-fit: cover; }
  .modal-nav {
    position: absolute; top: 50%; transform: translateY(-50%);
    width: 36px; height: 36px; border-radius: 50%;
    background: rgba(15,31,25,.6); border: none; color: var(--beige-50);
    font-size: 1.3rem; cursor: pointer; display: flex; align-items: center; justify-content: center;
  }
  .modal-prev { left: 8px; }
  .modal-next { right: 8px; }
  .modal-contador { text-align: center; color: rgba(248,242,230,.5); font-size: .75rem; margin-top: 10px; }

  .reveal { opacity: 0; transform: translateY(18px); transition: opacity .7s ease, transform .7s ease; }
  .reveal.in { opacity: 1; transform: translateY(0); }
</style>

<script define:vars={{ sectores: SECTORES }}>
  const tiles = document.querySelectorAll('.tile');
  const modal = document.getElementById('sector-modal');
  const modalImg = document.getElementById('sector-modal-img');
  const modalTitulo = document.getElementById('sector-modal-titulo');
  const modalFrase = document.getElementById('sector-modal-frase');
  const modalContador = document.getElementById('sector-modal-contador');
  const btnCerrar = document.getElementById('sector-modal-cerrar');
  const btnPrev = document.getElementById('sector-modal-prev');
  const btnNext = document.getElementById('sector-modal-next');

  let sectorActual = null;
  let indiceActual = 0;

  function render() {
    if (!sectorActual) return;
    modalImg.src = sectorActual.imgs[indiceActual];
    modalImg.alt = `${sectorActual.nombre} - foto ${indiceActual + 1}`;
    modalContador.textContent = `${indiceActual + 1} / ${sectorActual.imgs.length}`;
  }

  function abrir(sectorId) {
    sectorActual = sectores.find(s => s.id === sectorId);
    if (!sectorActual) return;
    indiceActual = 0;
    modalTitulo.textContent = `${sectorActual.icon} ${sectorActual.nombre}`;
    modalFrase.textContent = sectorActual.frase;
    render();
    modal.classList.remove('hidden');
  }

  function cerrar() { modal.classList.add('hidden'); }

  tiles.forEach(tile => tile.addEventListener('click', () => abrir(tile.dataset.sectorId)));
  btnCerrar.addEventListener('click', cerrar);
  modal.addEventListener('click', e => { if (e.target === modal) cerrar(); });
  btnPrev.addEventListener('click', () => {
    if (!sectorActual) return;
    indiceActual = (indiceActual - 1 + sectorActual.imgs.length) % sectorActual.imgs.length;
    render();
  });
  btnNext.addEventListener('click', () => {
    if (!sectorActual) return;
    indiceActual = (indiceActual + 1) % sectorActual.imgs.length;
    render();
  });
  document.addEventListener('keydown', e => {
    if (modal.classList.contains('hidden')) return;
    if (e.key === 'Escape') cerrar();
    if (e.key === 'ArrowLeft') btnPrev.click();
    if (e.key === 'ArrowRight') btnNext.click();
  });

  const io = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('in'); });
  }, { threshold: 0.12 });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));
</script>
