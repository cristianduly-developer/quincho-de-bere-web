<section class="max-w-5xl mx-auto px-6 py-20 md:py-28">
  <div class="text-center max-w-2xl mx-auto mb-10">
    <p class="text-xs uppercase tracking-[0.2em] text-madera-600 font-semibold mb-3">Recorrido</p>
    <h2 class="font-display text-3xl md:text-4xl font-semibold text-verde-950">Un paseo por el Quincho</h2>
    <p class="mt-4 text-verde-900/70">Así se vive el lugar, de la mano de Cristian.</p>
  </div>

  <div class="rounded-3xl overflow-hidden shadow-2xl border border-verde-800/10">
    <video
      class="w-full aspect-video object-cover bg-verde-950"
      controls
      preload="metadata"
      poster="/img/logo.jpeg"
    >
      <source src="/video/recorrido.mp4" type="video/mp4" />
      Tu navegador no soporta el video.
    </video>
  </div>
</section>
