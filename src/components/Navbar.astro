---
import { waLink, NEGOCIO } from '../data/negocio';
---
<div class="notice-bar">
  Estamos en reformas y <strong>reabrimos el 15 de septiembre</strong> — ya podés consultar tu fecha
</div>

<nav id="nav">
  <div class="nav-inner">
    <a href="#" class="brand">
      <img src="/img/logo.jpeg" alt={NEGOCIO.nombre} />
      <span class="brand-text">{NEGOCIO.nombre}</span>
    </a>
    <div class="nav-links">
      <a href="#sectores">Sectores</a>
      <a href="#turnos">Turnos</a>
      <a href="#extras">Extras</a>
      <a href="#opiniones">Opiniones</a>
      <a href="#faq">Preguntas</a>
    </div>
    <div class="nav-cta">
      <a class="btn btn-primary" href={waLink('Hola! Quiero consultar disponibilidad en El Quincho de Bere.')} target="_blank" rel="noopener noreferrer">
        Consultar por WhatsApp
      </a>
    </div>
  </div>
</nav>

<style>
  .notice-bar {
    background: var(--verde-950);
    color: var(--beige-100);
    font-size: .82rem;
    text-align: center;
    padding: 9px 16px;
    letter-spacing: .01em;
  }
  .notice-bar strong { color: var(--oro-400); }

  nav {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 24px;
    transition: background .3s ease, box-shadow .3s ease, padding .3s ease;
  }
  nav.scrolled {
    background: rgba(255,252,246,.92);
    backdrop-filter: blur(10px);
    box-shadow: 0 1px 0 rgba(15,31,25,.08);
    padding: 10px 24px;
  }
  .nav-inner {
    max-width: 1180px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.05rem;
    text-decoration: none;
  }
  .brand img {
    width: 38px; height: 38px;
    border-radius: 50%;
    object-fit: cover;
    background: #fff;
    padding: 2px;
  }
  .brand-text { color: var(--verde-950); }
  .nav-links {
    display: flex;
    gap: 28px;
    font-size: .88rem;
    font-weight: 600;
  }
  .nav-links a {
    color: var(--verde-900);
    text-decoration: none;
    transition: color .2s;
  }
  .nav-links a:hover { color: var(--oro-500); }
  .nav-cta { display: flex; align-items: center; gap: 14px; }
  .nav-cta .btn { padding: .6rem 1.3rem; font-size: .82rem; }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    padding: .95rem 1.9rem;
    border-radius: 999px;
    font-weight: 700;
    font-size: .92rem;
    transition: transform .18s ease, box-shadow .18s ease;
    white-space: nowrap;
    text-decoration: none;
  }
  .btn-primary {
    background: var(--oro-400);
    color: var(--verde-950);
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 24px -8px rgba(212,175,106,.55);
  }

  @media (max-width: 860px) { .nav-links { display: none; } }
</style>

<script>
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 40);
  }, { passive: true });
</script>
