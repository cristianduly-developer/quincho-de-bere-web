---
const reseñas = [
  { nombre: "Valentina R.", evento: "Cumpleaños de 15", texto: "Un lugar hermoso, la pileta y el parque hicieron todo más divertido. Cristian estuvo atento a cada detalle." },
  { nombre: "Marcos D.", evento: "Reunión familiar", texto: "Volvimos varias veces ya. El quincho está súper equipado y no falta nada, se siente como estar en casa." },
  { nombre: "Familia Gómez", evento: "Cumpleaños infantil", texto: "Los chicos la pasaron increíble con los juegos y la pileta. Excelente atención de principio a fin." },
];
---
<section id="opiniones" class="reveal">
  <div class="wrap">
    <p class="eyebrow">Opiniones</p>
    <h2 class="headline">Lo que dicen quienes<br/>ya vivieron su <em>evento</em> acá.</h2>

    <div class="quotes">
      {reseñas.map((r) => (
        <div class="quote-card">
          <div class="stars">★★★★★</div>
          <blockquote>"{r.texto}"</blockquote>
          <div class="who">{r.nombre}<span>{r.evento}</span></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  section { padding: 96px 0; }
  .wrap { max-width: 1180px; margin: 0 auto; padding: 0 24px; }
  .eyebrow { font-size: .72rem; letter-spacing: .22em; text-transform: uppercase; color: var(--madera-600); font-weight: 700; margin: 0 0 12px; }
  .headline { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.9rem, 3.6vw, 2.8rem); line-height: 1.1; margin: 0 0 44px; letter-spacing: -0.01em; }
  .headline em { font-style: italic; color: var(--madera-600); font-weight: 500; }

  .quotes { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
  @media(max-width: 900px) { .quotes { grid-template-columns: 1fr; } }

  .quote-card { background: var(--beige-100); border-radius: 20px; padding: 30px 26px; }
  .quote-card .stars { color: var(--oro-500); font-size: .85rem; margin-bottom: 14px; letter-spacing: 2px; }
  .quote-card blockquote {
    font-family: var(--font-display); font-style: italic; font-weight: 400;
    font-size: 1.08rem; line-height: 1.45; margin: 0 0 18px; color: var(--verde-950);
  }
  .quote-card .who { font-size: .82rem; font-weight: 700; color: var(--verde-900); }
  .quote-card .who span { display: block; font-weight: 500; color: rgba(15,31,25,.5); font-size: .78rem; }

  .reveal { opacity: 0; transform: translateY(18px); transition: opacity .7s ease, transform .7s ease; }
  .reveal.in { opacity: 1; transform: translateY(0); }
</style>
