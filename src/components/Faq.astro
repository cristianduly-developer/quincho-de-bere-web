---
import { FAQS } from '../data/negocio';
---
<section class="bg-beige-100 py-20 md:py-28">
  <div class="max-w-3xl mx-auto px-6">
    <div class="text-center mb-12">
      <p class="text-xs uppercase tracking-[0.2em] text-madera-600 font-semibold mb-3">Preguntas frecuentes</p>
      <h2 class="font-display text-3xl md:text-4xl font-semibold text-verde-950">¿Tenés dudas?</h2>
    </div>

    <div class="space-y-3">
      {FAQS.map((faq) => (
        <details class="group bg-white rounded-xl border border-verde-800/8 open:shadow-md transition-shadow">
          <summary class="cursor-pointer list-none flex items-center justify-between px-5 py-4 font-display font-semibold text-verde-950 text-sm md:text-base">
            {faq.q}
            <span class="ml-4 shrink-0 text-verde-800/50 group-open:rotate-45 transition-transform text-xl leading-none">+</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-verde-900/70 leading-relaxed">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
