---
import { FAQS } from '../data/negocio';
---
<section id="faq" class="reveal">
  <div class="wrap">
    <p class="eyebrow" style="text-align:center">Preguntas frecuentes</p>
    <h2 class="headline" style="text-align:center">¿Tenés dudas?<br/>Acá te las <em>resolvemos</em>.</h2>

    <div class="faq-list">
      {FAQS.map((faq) => (
        <div class="faq-item">
          <button class="faq-q">{faq.q} <span class="plus">+</span></button>
          <div class="faq-a"><p>{faq.a}</p></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  section { padding: 96px 0; }
  .wrap { max-width: 1180px; margin: 0 auto; padding: 0 24px; }
  .eyebrow { font-size: .72rem; letter-spacing: .22em; text-transform: uppercase; color: var(--madera-600); font-weight: 700; margin: 0 0 12px; }
  .headline { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.9rem, 3.6vw, 2.8rem); line-height: 1.1; margin: 0 0 0; letter-spacing: -0.01em; }
  .headline em { font-style: italic; color: var(--madera-600); font-weight: 500; }

  .faq-list { max-width: 760px; margin: 44px auto 0; }
  .faq-item { border-bottom: 1px solid rgba(15,31,25,.12); }
  .faq-q {
    width: 100%; text-align: left; background: none; border: none; cursor: pointer;
    padding: 20px 0; display: flex; justify-content: space-between; align-items: center; gap: 16px;
    font-family: var(--font-display); font-weight: 600; font-size: 1.02rem; color: var(--verde-950);
  }
  .faq-q .plus { font-size: 1.3rem; color: var(--madera-600); transition: transform .25s ease; flex: none; }
  .faq-item.open .plus { transform: rotate(45deg); }
  .faq-a { max-height: 0; overflow: hidden; transition: max-height .3s ease; }
  .faq-a p { margin: 0 0 20px; color: rgba(15,31,25,.62); font-size: .92rem; line-height: 1.6; max-width: 60ch; }

  .reveal { opacity: 0; transform: translateY(18px); transition: opacity .7s ease, transform .7s ease; }
  .reveal.in { opacity: 1; transform: translateY(0); }
</style>

<script>
  document.querySelectorAll('.faq-item').forEach(item => {
    const q = item.querySelector('.faq-q');
    const a = item.querySelector('.faq-a') as HTMLElement;
    q?.addEventListener('click', () => {
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item.open').forEach(o => {
        o.classList.remove('open');
        (o.querySelector('.faq-a') as HTMLElement).style.maxHeight = '';
      });
      if (!isOpen) {
        item.classList.add('open');
        a.style.maxHeight = a.scrollHeight + 'px';
      }
    });
  });
</script>
