---
import { TURNOS, waLink } from '../data/negocio';

const iconos: Record<string, string> = { dia: '☀️', noche: '🌙', completo: '✨' };
const descripciones: Record<string, string> = {
  dia: 'Ideal para cumpleaños infantiles: sol, pileta y toda la tarde de juegos.',
  noche: 'Fogón encendido, luces cálidas y la previa perfecta entre amigos.',
  completo: 'Del mediodía hasta la noche cerrada — sin apurar ningún momento.',
};
---
<section id="turnos" class="dayarc">
  <div class="wrap">
    <p class="eyebrow">Tu evento, a tu ritmo</p>
    <h2 class="headline">Un día entero,<br/>de <em>principio a fin</em>.</h2>
    <p class="lead">Del mediodía al fogón de la noche: elegí el turno que mejor se acomode a tu celebración.</p>

    <div class="arc-track">
      <div class="arc-line"></div>
      <div class="arc-stops">
        {TURNOS.map((turno) => (
          <div class="stop">
            <div class="stop-dot">{iconos[turno.tipo]}</div>
            <div class="stop-card">
              <h3>{turno.nombre}</h3>
              <div class="hrs">{turno.horario}</div>
              <p>{descripciones[turno.tipo]}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="arc-cta">
      <a href={waLink('Hola! Quiero consultar disponibilidad en El Quincho de Bere.')} target="_blank" rel="noopener noreferrer" class="btn btn-gold">
        Consultar disponibilidad
      </a>
    </div>
  </div>
</section>

<style>
  .dayarc {
    position: relative;
    background: var(--verde-950);
    color: var(--beige-50);
    overflow: hidden;
    padding: 96px 0;
  }
  .dayarc::before {
    content: "";
    position: absolute; inset: 0;
    background: linear-gradient(100deg, #efe4d0 0%, #d4af6a 30%, #8b5e3c 55%, #16302a 80%, #0f1f19 100%);
    opacity: .09;
  }
  .wrap { position: relative; z-index: 1; max-width: 1180px; margin: 0 auto; padding: 0 24px; }
  .eyebrow {
    font-size: .72rem; letter-spacing: .22em; text-transform: uppercase;
    color: rgba(255,252,246,.75); font-weight: 700; margin: 0 0 12px;
  }
  .headline {
    font-family: var(--font-display); font-weight: 600; color: var(--beige-50);
    font-size: clamp(1.9rem, 3.6vw, 2.8rem);
    line-height: 1.1; margin: 0 0 14px; letter-spacing: -0.01em;
  }
  .headline em { font-style: italic; color: var(--beige-50); font-weight: 500; text-decoration: underline; text-decoration-color: rgba(255,252,246,.3); text-underline-offset: 6px; }
  .lead { color: rgba(255,252,246,.72); font-size: 1.02rem; line-height: 1.6; max-width: 46ch; }

  .arc-track { position: relative; margin-top: 70px; padding-top: 10px; }
  .arc-line {
    position: absolute; top: 26px; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, rgba(255,252,246,.5), rgba(255,252,246,.1));
  }
  .arc-stops { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; position: relative; }
  @media(max-width: 820px) {
    .arc-stops { grid-template-columns: 1fr; gap: 40px; }
    .arc-line { display: none; }
  }
  .stop { position: relative; padding-top: 52px; }
  .stop-dot {
    position: absolute; top: 12px; left: 0;
    width: 28px; height: 28px; border-radius: 50%;
    background: var(--verde-950); border: 2px solid var(--oro-400);
    display: flex; align-items: center; justify-content: center; font-size: .85rem;
  }
  .stop-card {
    background: rgba(255,252,246,.08); border: 1px solid rgba(255,252,246,.18);
    border-radius: 18px; padding: 22px 22px 24px; backdrop-filter: blur(6px);
  }
  .stop-card h3 { font-family: var(--font-display); font-weight: 600; font-size: 1.15rem; margin: 0 0 4px; color: var(--beige-50); }
  .stop-card .hrs { color: var(--oro-400); font-weight: 700; font-size: .85rem; margin-bottom: 10px; }
  .stop-card p { margin: 0; font-size: .85rem; color: rgba(255,252,246,.72); line-height: 1.55; }

  .arc-cta { margin-top: 48px; text-align: center; }
  .btn {
    display: inline-flex; align-items: center; gap: .5rem;
    padding: .95rem 2rem; border-radius: 999px;
    font-weight: 700; font-size: .92rem;
    transition: transform .18s ease, box-shadow .18s ease;
    white-space: nowrap; text-decoration: none;
  }
  .btn-gold { background: var(--oro-400); color: var(--verde-950); }
  .btn-gold:hover { transform: translateY(-2px); box-shadow: 0 10px 24px -8px rgba(212,175,106,.55); }
</style>
