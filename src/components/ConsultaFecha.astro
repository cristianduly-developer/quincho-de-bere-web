---
import { NEGOCIO, TURNOS, DISPONIBILIDAD } from '../data/negocio';
---
<section class="max-w-md mx-auto px-6 -mt-16 relative z-20">
  <div class="bg-beige-50 rounded-3xl shadow-xl border border-verde-800/10 p-6 md:p-8">
    <p class="text-xs uppercase tracking-[0.2em] text-madera-600 font-semibold mb-1 text-center">Consultá tu fecha</p>
    <h2 class="font-display text-xl md:text-2xl font-semibold text-verde-950 text-center mb-5">
      Mirá la disponibilidad real
    </h2>

    <div class="flex items-center justify-between mb-2">
      <button id="cf-prev" type="button" aria-label="Mes anterior" class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-verde-800/10 text-verde-900">‹</button>
      <span id="cf-mes-label" class="font-display font-semibold text-verde-950 text-sm capitalize"></span>
      <button id="cf-next" type="button" aria-label="Mes siguiente" class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-verde-800/10 text-verde-900">›</button>
    </div>

    <div class="grid grid-cols-7 gap-1 text-center text-[10px] text-verde-900/50 font-semibold mb-1">
      <span>L</span><span>M</span><span>X</span><span>J</span><span>V</span><span>S</span><span>D</span>
    </div>
    <div id="cf-grid" class="grid grid-cols-7 gap-1"></div>

    <div class="flex flex-wrap gap-x-4 gap-y-1 mt-4 text-[11px] text-verde-900/60">
      <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full" style="background:#639922"></span>Libre</span>
      <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full" style="background:#EF9F27"></span>Un turno libre</span>
      <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full" style="background:#D85A30"></span>Ocupado</span>
      <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full" style="background:#E2DED2"></span>No disponible</span>
    </div>

    <div class="mt-5">
      <label for="cf-turno" class="block text-xs font-semibold text-verde-900/70 mb-1.5">Turno</label>
      <select
        id="cf-turno"
        class="w-full rounded-xl bg-white border border-verde-800/15 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-oro-400"
      >
        {TURNOS.map((t) => (
          <option value={`${t.nombre} (${t.horario})`} data-tipo={t.tipo}>{t.nombre} — {t.horario}</option>
        ))}
      </select>
      <p id="cf-turno-aviso" class="hidden text-xs text-madera-600 mt-1.5"></p>
    </div>

    <p id="cf-aviso" class="hidden mt-4 text-sm bg-madera-500/10 text-madera-700 border border-madera-500/20 rounded-xl px-4 py-3"></p>

    <a
      id="cf-boton"
      href="#"
      target="_blank"
      rel="noopener noreferrer"
      class="btn-primary w-full justify-center mt-5 opacity-40 pointer-events-none"
    >
      Elegí una fecha libre
    </a>
    <p class="text-xs text-verde-900/50 text-center mt-3">
      Esto no reserva nada — solo nos avisa qué fecha te interesa para coordinar por WhatsApp.
    </p>
  </div>
</section>

<script define:vars={{
  whatsappNumero: NEGOCIO.whatsappNumero,
  reaperturaFecha: NEGOCIO.reaperturaFecha,
  supabaseUrl: DISPONIBILIDAD.supabaseUrl,
  supabaseAnonKey: DISPONIBILIDAD.supabaseAnonKey,
  orgId: DISPONIBILIDAD.orgId,
}}>
  const grid = document.getElementById('cf-grid');
  const mesLabel = document.getElementById('cf-mes-label');
  const prevBtn = document.getElementById('cf-prev');
  const nextBtn = document.getElementById('cf-next');
  const turnoSelect = document.getElementById('cf-turno');
  const turnoAviso = document.getElementById('cf-turno-aviso');
  const aviso = document.getElementById('cf-aviso');
  const boton = document.getElementById('cf-boton');

  const hoy = new Date();
  hoy.setHours(0, 0, 0, 0);
  let mesActual = new Date(hoy.getFullYear(), hoy.getMonth(), 1);
  let fechaSeleccionada = null;
  let ocupacion = new Map(); // fecha -> { dia: bool, noche: bool }
  let cargando = true;

  function ymd(d) {
    return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0');
  }

  async function cargarOcupadas() {
    try {
      const res = await fetch(`${supabaseUrl}/rest/v1/rpc/get_disponibilidad`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'apikey': supabaseAnonKey,
          'Authorization': `Bearer ${supabaseAnonKey}`,
        },
        body: JSON.stringify({ p_org_id: orgId }),
      });
      if (res.ok) {
        const data = await res.json();
        ocupacion = new Map(data.map((r) => [r.fecha, { dia: !!r.dia_ocupado, noche: !!r.noche_ocupado }]));
      }
    } catch (e) {
      // Si falla la consulta, seguimos mostrando el calendario sin marcar ocupados.
    }
    cargando = false;
    render();
  }

  function render() {
    mesLabel.textContent = mesActual.toLocaleDateString('es-AR', { month: 'long', year: 'numeric' });

    const primerDiaSemana = (mesActual.getDay() + 6) % 7; // lunes = 0
    const diasEnMes = new Date(mesActual.getFullYear(), mesActual.getMonth() + 1, 0).getDate();

    grid.innerHTML = '';
    for (let i = 0; i < primerDiaSemana; i++) {
      grid.appendChild(document.createElement('div'));
    }

    for (let dia = 1; dia <= diasEnMes; dia++) {
      const fecha = new Date(mesActual.getFullYear(), mesActual.getMonth(), dia);
      const fechaStr = ymd(fecha);
      const esPasado = fecha < hoy;
      const esReformas = fechaStr < reaperturaFecha;
      const noDisponible = esPasado || esReformas || cargando;

      const est = ocupacion.get(fechaStr) || { dia: false, noche: false };
      const totalmenteOcupado = est.dia && est.noche;
      const parcialmenteOcupado = est.dia !== est.noche;

      const btn = document.createElement('button');
      btn.type = 'button';
      btn.textContent = String(dia);
      btn.className = 'h-9 rounded-lg text-xs font-medium flex items-center justify-center transition-colors';

      if (noDisponible) {
        btn.style.background = '#E2DED2';
        btn.style.color = '#8B897F';
        btn.classList.add('cursor-not-allowed');
        btn.disabled = true;
      } else if (totalmenteOcupado) {
        btn.style.background = '#D85A30';
        btn.style.color = '#ffffff';
        btn.classList.add('cursor-not-allowed');
        btn.disabled = true;
      } else if (parcialmenteOcupado) {
        btn.style.background = '#EF9F27';
        btn.style.color = '#3D2600';
        btn.classList.add('hover:opacity-80', 'cursor-pointer');
        if (fechaStr === fechaSeleccionada) {
          btn.style.outline = '2px solid #16302A';
          btn.style.outlineOffset = '1px';
        }
        btn.addEventListener('click', () => {
          fechaSeleccionada = fechaStr;
          render();
          actualizarTurnos();
        });
      } else {
        btn.style.background = fechaStr === fechaSeleccionada ? '#16302A' : '#639922';
        btn.style.color = '#ffffff';
        btn.classList.add('hover:opacity-80', 'cursor-pointer');
        btn.addEventListener('click', () => {
          fechaSeleccionada = fechaStr;
          render();
          actualizarTurnos();
        });
      }
      grid.appendChild(btn);
    }

    prevBtn.disabled = mesActual.getFullYear() === hoy.getFullYear() && mesActual.getMonth() === hoy.getMonth();
    prevBtn.classList.toggle('opacity-30', prevBtn.disabled);
  }

  function actualizarTurnos() {
    const est = fechaSeleccionada ? (ocupacion.get(fechaSeleccionada) || { dia: false, noche: false }) : { dia: false, noche: false };

    [...turnoSelect.options].forEach((opt) => {
      const tipo = opt.getAttribute('data-tipo');
      const bloqueado = (tipo === 'dia' && est.dia) || (tipo === 'noche' && est.noche) || (tipo === 'completo' && (est.dia || est.noche));
      opt.disabled = bloqueado;
    });

    if (turnoSelect.selectedOptions[0]?.disabled) {
      const primeraLibre = [...turnoSelect.options].find((o) => !o.disabled);
      if (primeraLibre) turnoSelect.value = primeraLibre.value;
    }

    if (fechaSeleccionada && (est.dia || est.noche)) {
      turnoAviso.textContent = 'Para esta fecha ya hay un turno ocupado — dejamos seleccionado el que sigue libre.';
      turnoAviso.classList.remove('hidden');
    } else {
      turnoAviso.classList.add('hidden');
    }

    actualizarBoton();
  }

  function actualizarBoton() {
    if (!fechaSeleccionada) {
      boton.classList.add('opacity-40', 'pointer-events-none');
      boton.textContent = 'Elegí una fecha libre';
      aviso.classList.add('hidden');
      return;
    }
    boton.classList.remove('opacity-40', 'pointer-events-none');
    boton.textContent = 'Consultar por WhatsApp';
    aviso.classList.add('hidden');

    const turno = turnoSelect.value;
    const fechaFormateada = new Date(fechaSeleccionada + 'T00:00:00').toLocaleDateString('es-AR', { day: 'numeric', month: 'long', year: 'numeric' });
    const mensaje = `Hola! Quiero consultar disponibilidad en El Quincho de Bere para el ${fechaFormateada}, ${turno}.`;
    boton.href = `https://wa.me/${whatsappNumero}?text=${encodeURIComponent(mensaje)}`;
  }

  prevBtn.addEventListener('click', () => {
    mesActual = new Date(mesActual.getFullYear(), mesActual.getMonth() - 1, 1);
    render();
  });
  nextBtn.addEventListener('click', () => {
    mesActual = new Date(mesActual.getFullYear(), mesActual.getMonth() + 1, 1);
    render();
  });
  turnoSelect.addEventListener('change', actualizarBoton);

  render();
  cargarOcupadas();
</script>
